<Window x:Class="RecipeBook.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронная книга рецептов" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SelectedCategoryId}" Width="120" Margin="0,0,10,0">
                <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ComboBox.ItemsPanel>
            </ComboBox>
            <ComboBox SelectedValue="{Binding SelectedTimeFilter}" Width="100">
                <ComboBoxItem Content="Любое" Tag="{x:Null}"/>
                <ComboBoxItem Content="≤ 15 мин" Tag="15"/>
                <ComboBoxItem Content="≤ 30 мин" Tag="30"/>
                <ComboBoxItem Content="≤ 60 мин" Tag="60"/>
            </ComboBox>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Recipes}" SelectedItem="{Binding Selected}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="250"/>
                    <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding Category.Name}" Width="150"/>
                    <GridViewColumn Header="Время (мин)" DisplayMemberBinding="{Binding CookTimeMinutes}" Width="100"/>
                    <GridViewColumn Header="Сложность" DisplayMemberBinding="{Binding Difficulty}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Просмотр" Command="{Binding ViewCommand}" Margin="5"/>
            <Button Content="Добавить" Command="{Binding AddCommand}" Margin="5"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Margin="5"/>
            <Button Content="Экспорт JSON" Command="{Binding ExportJsonCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>