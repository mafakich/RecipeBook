<Window x:Class="RecipeBook.App.RecipeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:RecipeBook.Core;assembly=RecipeBook.Core"
        Title="Добавление / Редактирование рецепта" 
        Height="580" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Название рецепта:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,4,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Категория:" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Categories}" 
                                  DisplayMemberPath="Name" 
                                  SelectedValue="{Binding CategoryId}" 
                                  SelectedValuePath="Id" 
                                  Margin="0,4,0,12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Время (мин):" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding CookTime, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,4,0,12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Сложность:" FontWeight="SemiBold"/>
                        <ComboBox SelectedItem="{Binding Difficulty}" Margin="0,4,0,12">
                            <ComboBoxItem Content="Easy"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="Hard"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Ингредиенты:" FontWeight="SemiBold" Margin="0,8,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox ItemsSource="{Binding SelectedIngredients}" 
                             DisplayMemberPath="Name" 
                             Height="90" 
                             Grid.Column="0" 
                             Margin="0,0,8,0"
                             BorderThickness="1"/>

                    <StackPanel Grid.Column="1" Width="110">
                        <ComboBox ItemsSource="{Binding AllIngredients}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding ChosenIngredient}" 
                                  Margin="0,0,0,6"/>
                        <Button Content="➕ Добавить" 
                                Command="{Binding AddIngredientCommand}" 
                                Margin="0,0,0,6"/>
                        <Button Content="➖ Удалить последний" 
                                Command="{Binding RemoveIngredientCommand}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Шаги приготовления:" FontWeight="SemiBold" Margin="0,16,0,4"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox ItemsSource="{Binding Steps}" 
                             Height="110" 
                             BorderThickness="1" 
                             Grid.Row="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4">
                                    <TextBlock Text="{Binding StepNumber, StringFormat='#{0}. '}" 
                                               FontWeight="Bold" Width="30"/>
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="320" Margin="4,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="➕ Добавить шаг" 
                                Command="{Binding AddStepCommand}" 
                                Margin="0,0,8,0"/>
                        <Button Content="➖ Удалить последний" 
                                Command="{Binding RemoveStepCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Сохранить" 
                    Command="{Binding SaveCommand}" 
                    Width="120" Margin="0,0,8,0"/>
            <Button Content="❌ Отмена" 
                    Click="Cancel_Click" 
                    Width="120"/>
        </StackPanel>
    </Grid>
</Window>